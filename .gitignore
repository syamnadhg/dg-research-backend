__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.env
.dg-supervisor.env

# Firebase Admin SDK key — NEVER commit. Sammy emails this personally.
# Drop it at: research-automate/firebase-service-account.json
firebase-service-account.json

# Per-machine local state — backend writes these on --setup / --serve.
pipe_config.json
research_config.json
device_config.json
run_analytics.json
backend.log
backend.err.log
daemon.log
daemon.err.log

# Playwright user data (logged-in browser sessions) stays local.
.playwright-profile/
playwright-profile/

# Pipeline output — not source. Keep the README so the queues/{run}/
# schema stays discoverable in the repo. (tracks/ removed 2026-04-29 —
# the directory tree is gone and so are the `tracks/*` ignore lines.)
queues/*
!queues/README.md

# Runtime debug logs from `python research.py --serve 2>&1 | tee logs/...`
# and one-off resume_phase2_*.log dumps. Local-only.
logs/
*.log

# Scratch — design notes, hotspot maps, throwaway test scripts. Local-only;
# anything worth keeping graduates to a real file in the repo root.
scratch/

# Vision fixtures — hotspot screenshots may contain authed-session UI
# (email addresses, account chips). Captured locally during E2E via
# `python vision_test.py --capture NAME`. The README stays in the repo
# so the schema is discoverable.
tests/fixtures/vision/*.png
tests/fixtures/vision/*.json
