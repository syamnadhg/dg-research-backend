__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.env

# Firebase Admin SDK key — NEVER commit. Sammy emails this personally.
# Drop it at: research-automate/firebase-service-account.json
firebase-service-account.json

# Per-machine local state — backend writes these on --setup / --serve.
pipe_config.json
research_config.json
device_config.json
run_analytics.json
backend.log
backend.err.log
daemon.log
daemon.err.log

# Playwright user data (logged-in browser sessions) stays local.
.playwright-profile/
playwright-profile/

# Pipeline output — not source. Keep the README in each dir so the
# schemas for queues/*/ and tracks/*/ stay discoverable in the repo.
queues/*
!queues/README.md
tracks/*
!tracks/README.md

# Runtime debug logs from `python research.py --serve 2>&1 | tee logs/...`
# and one-off resume_phase2_*.log dumps. Local-only.
logs/
*.log
